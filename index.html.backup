<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iconik Games - Small Team. Big Ideas. Every Move Counts.</title>
    <link rel="stylesheet" href="css/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Language Toggle & Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="#" class="logo">
                <img src="assets/images/logo.png" alt="Iconik Games Logo">
            </a>
            <div class="nav-menu">
                <a href="#project" class="nav-link t">Our Project</a>
                <a href="#guilds" class="nav-link t">Guilds</a>
                <a href="#gameplay" class="nav-link t">Gameplay</a>
                <a href="#team" class="nav-link t">Team</a>
                <button class="lang-toggle" id="langToggle">
                    <span class="lang-option" data-lang="en">EN</span>
                    <span class="lang-option active" data-lang="fr">FR</span>
                </button>
            </div>
            <button class="mobile-menu-toggle" id="mobileMenuToggle">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-background">
            <img src="assets/images/hero-city.jpg" alt="City of Sylleria">
            <div class="hero-overlay"></div>
        </div>
        <div class="hero-content">
            <h1 class="hero-title t">Iconik Games</h1>
            <h2 class="hero-subtitle t">Small team. Big ideas. Every move counts.</h2>
            <p class="hero-description t">We create engaging and meaningful games built on innovative mechanics designed to inspire players and have a positive impact on their lives.</p>
        </div>
        <div class="scroll-indicator">
            <div class="scroll-arrow"></div>
        </div>
    </section>

    <!-- Project Section -->
    <section id="project" class="section project-section">
        <div class="container">
            <h2 class="section-label t">Our project</h2>
            <div class="project-header">
                <h3 class="project-title t">Monarchs of Sylleria</h3>
            </div>

            <div class="feature-grid">
                <div class="feature-card">
                    <div class="feature-content">
                        <h4 class="t">A City of Wonder, Mystery, and Wealth</h4>
                        <p class="t">Sylleria is the vibrant, industrial heart of the world, sitting at the crossroads of every major trade route. While many have tried to conquer it by force, the city remains "free"—not because it lacks masters, but because its true power is hidden behind gold and secrets rather than stone walls.</p>
                    </div>
                </div>

                <div class="feature-card">
                    <div class="feature-content">
                        <h4 class="t">The Fight for Power</h4>
                        <p class="t">Step into the "Great Game" as a Monarch from distant lands. You cannot rule Sylleria through decree alone; you must outmaneuver rivals in a never-ending ballet of intrigues. Every move you make is a calculated risk to claim the city's immense resources for your own kingdom.</p>
                    </div>
                </div>

                <div class="feature-card">
                    <div class="feature-content">
                        <h4 class="t">Master the Guilds</h4>
                        <p class="t">In Sylleria, power waxes and wanes with your reputation. Build your influence by forming deep affinities with the powerful Guilds that run the city. As you level up your standing, you unlock unique alliances and industrial secrets—but beware, in this city, a "loyal" ally is only one bad trade away from becoming a rival.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Guilds Section -->
    <section id="guilds" class="section guilds-section">
        <div class="container">
            <h2 class="section-label t">The guilds of Sylleria</h2>

            <div class="guilds-grid">
                <div class="guild-card">
                    <div class="guild-icon">
                        <img src="assets/images/guild-mercenaries.png" alt="Mercenaries">
                    </div>
                    <h4 class="guild-name" data-i18n="guilds.mercenaries.name"></h4>
                    <p class="guild-description" data-i18n="guilds.mercenaries.description"></p>
                </div>

                <div class="guild-card">
                    <div class="guild-icon">
                        <img src="assets/images/guild-alchemists.png" alt="Alchemists">
                    </div>
                    <h4 class="guild-name" data-i18n="guilds.alchemists.name"></h4>
                    <p class="guild-description" data-i18n="guilds.alchemists.description"></p>
                </div>

                <div class="guild-card">
                    <div class="guild-icon">
                        <img src="assets/images/guild-clerics.png" alt="Clerics">
                    </div>
                    <h4 class="guild-name" data-i18n="guilds.clerics.name"></h4>
                    <p class="guild-description" data-i18n="guilds.clerics.description"></p>
                </div>

                <div class="guild-card">
                    <div class="guild-icon">
                        <img src="assets/images/guild-cultists.png" alt="Cultists">
                    </div>
                    <h4 class="guild-name" data-i18n="guilds.cultists.name"></h4>
                    <p class="guild-description" data-i18n="guilds.cultists.description"></p>
                </div>

                <div class="guild-card">
                    <div class="guild-icon guild-icon-placeholder druids">
                        <span class="guild-icon-letter">D</span>
                    </div>
                    <h4 class="guild-name" data-i18n="guilds.druids.name"></h4>
                    <p class="guild-description" data-i18n="guilds.druids.description"></p>
                </div>

                <div class="guild-card">
                    <div class="guild-icon guild-icon-placeholder engineers">
                        <span class="guild-icon-letter">E</span>
                    </div>
                    <h4 class="guild-name" data-i18n="guilds.engineers.name"></h4>
                    <p class="guild-description" data-i18n="guilds.engineers.description"></p>
                </div>

                <div class="guild-card">
                    <div class="guild-icon guild-icon-placeholder thieves">
                        <span class="guild-icon-letter">T</span>
                    </div>
                    <h4 class="guild-name" data-i18n="guilds.thieves.name"></h4>
                    <p class="guild-description" data-i18n="guilds.thieves.description"></p>
                </div>

                <div class="guild-card">
                    <div class="guild-icon guild-icon-placeholder wizards">
                        <span class="guild-icon-letter">W</span>
                    </div>
                    <h4 class="guild-name" data-i18n="guilds.wizards.name"></h4>
                    <p class="guild-description" data-i18n="guilds.wizards.description"></p>
                </div>
            </div>
        </div>
    </section>

    <!-- Gameplay Section -->
    <section id="gameplay" class="section gameplay-section">
        <div class="container">
            <div class="gameplay-grid">
                <div class="gameplay-card">
                    <div class="gameplay-visual deck-visual">
                        <div class="card-stack">
                            <div class="game-card card-1"></div>
                            <div class="game-card card-2"></div>
                            <div class="game-card card-3"></div>
                        </div>
                    </div>
                    <div class="gameplay-content">
                        <h3 data-i18n="gameplay.deck.title"></h3>
                        <p data-i18n="gameplay.deck.description"></p>
                    </div>
                </div>

                <div class="gameplay-card reverse">
                    <div class="gameplay-visual board-visual">
                        <div class="game-board">
                            <div class="board-grid"></div>
                            <div class="board-pieces">
                                <div class="piece piece-1"></div>
                                <div class="piece piece-2"></div>
                                <div class="piece piece-3"></div>
                            </div>
                        </div>
                    </div>
                    <div class="gameplay-content">
                        <h3 data-i18n="gameplay.board.title"></h3>
                        <p data-i18n="gameplay.board.description"></p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Team Section -->
    <section id="team" class="section team-section">
        <div class="container">
            <h2 class="section-label" data-i18n="team.label"></h2>

            <div class="team-grid">
                <div class="team-member">
                    <div class="member-photo">
                        <div class="photo-placeholder">E</div>
                    </div>
                    <h4 class="member-name" data-i18n="team.eric.name"></h4>
                    <p class="member-role" data-i18n="team.eric.role"></p>
                </div>

                <div class="team-member">
                    <div class="member-photo">
                        <div class="photo-placeholder">J</div>
                    </div>
                    <h4 class="member-name" data-i18n="team.julien.name"></h4>
                    <p class="member-role" data-i18n="team.julien.role"></p>
                </div>

                <div class="team-member">
                    <div class="member-photo">
                        <div class="photo-placeholder">C</div>
                    </div>
                    <h4 class="member-name" data-i18n="team.charles.name"></h4>
                    <p class="member-role" data-i18n="team.charles.role"></p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-social">
                    <p data-i18n="footer.discord"></p>
                    <a href="https://discord.gg/qMFjj7VV" target="_blank" class="discord-link">
                        <svg width="40" height="40" viewBox="0 0 71 55" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <g clip-path="url(#clip0)">
                                <path d="M60.1045 4.8978C55.5792 2.8214 50.7265 1.2916 45.6527 0.41542C45.5603 0.39851 45.468 0.440769 45.4204 0.525289C44.7963 1.6353 44.105 3.0834 43.6209 4.2216C38.1637 3.4046 32.7345 3.4046 27.3892 4.2216C26.905 3.0581 26.1886 1.6353 25.5617 0.525289C25.5141 0.443589 25.4218 0.40133 25.3294 0.41542C20.2584 1.2888 15.4057 2.8186 10.8776 4.8978C10.8384 4.9147 10.8048 4.9429 10.7825 4.9795C1.57795 18.7309 -0.943561 32.1443 0.293408 45.3914C0.299005 45.4562 0.335386 45.5182 0.385761 45.5576C6.45866 50.0174 12.3413 52.7249 18.1147 54.5195C18.2071 54.5477 18.305 54.5139 18.3638 54.4378C19.7295 52.5728 20.9469 50.6063 21.9907 48.5383C22.0523 48.4172 21.9935 48.2735 21.8676 48.2256C19.9366 47.4931 18.0979 46.6 16.3292 45.5858C16.1893 45.5041 16.1781 45.304 16.3068 45.2082C16.679 44.9293 17.0513 44.6391 17.4067 44.3461C17.471 44.2926 17.5606 44.2813 17.6362 44.3151C29.2558 49.6202 41.8354 49.6202 53.3179 44.3151C53.3935 44.2785 53.4831 44.2898 53.5502 44.3433C53.9057 44.6363 54.2779 44.9293 54.6529 45.2082C54.7816 45.304 54.7732 45.5041 54.6333 45.5858C52.8646 46.6197 51.0259 47.4931 49.0921 48.2228C48.9662 48.2707 48.9102 48.4172 48.9718 48.5383C50.038 50.6034 51.2554 52.5699 52.5959 54.435C52.6519 54.5139 52.7526 54.5477 52.845 54.5195C58.6464 52.7249 64.529 50.0174 70.6019 45.5576C70.6551 45.5182 70.6887 45.459 70.6943 45.3942C72.1747 30.0791 68.2147 16.7757 60.1968 4.9823C60.1772 4.9429 60.1437 4.9147 60.1045 4.8978ZM23.7259 37.3253C20.2276 37.3253 17.3451 34.1136 17.3451 30.1693C17.3451 26.225 20.1717 23.0133 23.7259 23.0133C27.308 23.0133 30.1626 26.2532 30.1066 30.1693C30.1066 34.1136 27.28 37.3253 23.7259 37.3253ZM47.3178 37.3253C43.8196 37.3253 40.9371 34.1136 40.9371 30.1693C40.9371 26.225 43.7636 23.0133 47.3178 23.0133C50.9 23.0133 53.7545 26.2532 53.6986 30.1693C53.6986 34.1136 50.9 37.3253 47.3178 37.3253Z" fill="currentColor"/>
                            </g>
                            <defs>
                                <clipPath id="clip0">
                                    <rect width="71" height="55" fill="white"/>
                                </clipPath>
                            </defs>
                        </svg>
                    </a>
                </div>
                <p class="footer-note" data-i18n="footer.note"></p>
            </div>
        </div>
    </footer>

    <script src="js/i18n.js"></script>
    <script src="js/main.js"></script>
</body>
</html>
